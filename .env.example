# Kalshi API credentials (required for live/stress-test trading)
KALSHI_API_KEY_ID=your-api-key-id
KALSHI_PRIVATE_KEY_PATH=/path/to/your/private_key.pem

# Optional: override config values
# MONEYGONE_EXCHANGE__DEMO_MODE=true
# MONEYGONE_RISK__KELLY_FRACTION=0.25
# MONEYGONE_EXECUTION__MIN_EDGE_THRESHOLD=0.02
